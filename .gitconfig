[user]
    name = Darvin Basilio	
    email = darvin.basilio@gmail.com

[core]
    editor = code --wait
    autocrlf = input

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = false

[rebase]
    autoStash = true

# 🚫 Disable HTTPS credentials (SSH only)
[credential]
    helper = ""

# 🔁 Force GitHub to use SSH instead of HTTPS
[url "git@github.com:"]
    insteadOf = https://github.com/

# Useful aliases
[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    cam = commit -am
    lg = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1

[color]
    ui = auto